# ================================================================
# .env.example — copy this file to .env and fill in your values
# ================================================================
# HOW TO SET UP:
#   1. Copy this file:   cp .env.example .env
#   2. Fill in the values below in your .env file
#   3. Never commit .env to Git — it is already in .gitignore
# ================================================================

# Your Supabase PostgreSQL connection string
# Format: postgresql+psycopg2://username:password@host:port/database
DB_URL=postgresql+psycopg2://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-0-us-west-2.pooler.supabase.com:5432/postgres

# The schema you are querying (do not change this for the teaching project)
INDUSTRY=bootcamp_data

# Your personal learner schema (assigned by your instructor)
LEARNER_SCHEMA=instructor
